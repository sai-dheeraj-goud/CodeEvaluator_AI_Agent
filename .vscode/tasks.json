{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Server (Output Tab)",
      "type": "shell",
      "command": "node",
      "args": [
        "${workspaceFolder}/src/server.js"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false,
        "revealProblems": "onProblem"
      },
      "isBackground": false,
      "runOptions": {
        "instanceLimit": 1,
        "reevaluateOnRerun": true
      }
    },
    {
      "label": "View Server Logs",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-Command",
        "Get-Content -Path '${workspaceFolder}/logs/server.log' -Tail 100 -Wait"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      },
      "isBackground": true
    },
    {
      "label": "Clear Logs",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-Command",
        "Remove-Item -Path '${workspaceFolder}/logs/*' -Force -ErrorAction SilentlyContinue; Write-Host 'Logs cleared'"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
