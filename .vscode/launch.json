{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Server",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/server.js",
      "restart": true,
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "outputCapture": "std",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
