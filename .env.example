# ============================================================
# ENVIRONMENT CONFIGURATION — Copy this to .env and fill in
# ============================================================

# --- Server ---
# PORT is auto-set by cloud platforms (Render, Railway, etc.)
# Only change for local development
# PORT=3000

# --- Email Provider: 'resend', 'smtp', or 'auto' ---
EMAIL_PROVIDER=auto

# Resend API (HTTPS — works through corporate firewalls)
RESEND_API_KEY=
RESEND_FROM=Code Evaluator <onboarding@resend.dev>

# Default SMTP (Office 365 / Corporate)
# Gmail SMTP (for gmail recipients)
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_SMTP_USER=ctsqea260409@gmail.com
GMAIL_SMTP_PASS=ualo cifz sohw zpsl
GMAIL_SMTP_FROM=Code Evaluator

# Gmail SMTP
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_SMTP_USER=
GMAIL_SMTP_PASS=
GMAIL_SMTP_FROM=Code Evaluator

# ============================================================
# AI AGENT CONFIGURATION
# ============================================================

# --- Claude / Anthropic ---
USE_CLAUDE=false
CLAUDE_BASE_URL=
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- OpenAI (Cloud AI) ---
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Ollama (Local AI — not available in cloud deployments) ---
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

